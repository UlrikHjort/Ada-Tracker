--  Bitmap_Font
--  8*8 embedded bitmap font (VGA BIOS style, ASCII 32-127).
--  Renders each character as scaled pixel blocks using SDL2.

with Interfaces;   use Interfaces;
with Interfaces.C; use Interfaces.C;
with SDL2;

package Bitmap_Font is

   --  Character cell in the font bitmap: 8 rows of 8 pixels (LSB = leftmost)
   type Char_Row  is array (0 .. 7) of Unsigned_8;
   type Font_Data is array (32 .. 255) of Char_Row;
   --  Extended to 255 to support Latin-1 (ISO 8859-1) characters.
   --  128..255 are blank except for the few added below (e.g. ø at 248).

   Font : constant Font_Data;

   --  Scale factor: each font pixel becomes Scale*Scale screen pixels
   Scale : constant := 2;

   --  Screen dimensions of one character
   Char_W : constant := 8 * Scale;  --  16
   Char_H : constant := 8 * Scale;  --  16

   --  Draw a single character at screen position (X, Y) with given color.
   procedure Draw_Char
     (Rend : SDL2.SDL_Renderer;
      X, Y : int;
      Ch   : Character;
      R, G, B : Unsigned_8);

   --  Draw a string (no wrapping)
   procedure Draw_String
     (Rend : SDL2.SDL_Renderer;
      X, Y : int;
      Str  : String;
      R, G, B : Unsigned_8);

   --  Convenience: draw string with a pre-built color
   procedure Draw_String
     (Rend    : SDL2.SDL_Renderer;
      X, Y    : int;
      Str     : String;
      Col     : SDL2.SDL_Color);

private

